# ─────────────────────────────────────────────────────────────
#  Variables de entorno de Markify
#  Copia este archivo como  .env.local  y rellena los valores.
# ─────────────────────────────────────────────────────────────

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-public-key

# La conversión ocurre en el navegador: no hace falta nada más para convertir.

# Groq → https://console.groq.com/keys  (solo servidor, NUNCA se expone al navegador)
# Necesaria para el chat de IA. En Vercel: Settings → Environment Variables.
GROQ_API_KEY=gsk_tu-api-key-de-groq
