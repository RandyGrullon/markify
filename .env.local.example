# ─────────────────────────────────────────────────────────────
#  Variables de entorno de Markify
#  Copia este archivo como  .env.local  y rellena los valores.
# ─────────────────────────────────────────────────────────────

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-public-key

# (Opcional) URL del conversor. Por defecto usa /api/convert del mismo dominio.
# Solo cámbialo si despliegas el conversor Python en otro servicio.
# NEXT_PUBLIC_CONVERTER_URL=/api/convert
